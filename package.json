{
  "name": "crypto-side-screen",
  "version": "0.1.0",
  "description": "Crypto Side Screen — vertical split-screen monitor for Telegram alpha calls + social feeds",
  "private": true,
  "main": "dist-electron/main.js",
  "author": "Crypto Side Screen",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:web": "tsc -p tsconfig.app.json --noEmit && vite build --mode web",
    "preview": "vite preview",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:dist": "npm run build && electron-builder",
    "electron:dist:mac": "npm run build && electron-builder --mac",
    "electron:dist:win": "npm run build && electron-builder --win",
    "lint": "tsc -b --noEmit",
    "wechat:install": "cd vendor/wechat-decrypt && pip install -r requirements.txt",
    "wechat:start": "cd vendor/wechat-decrypt && python main.py",
    "dev:all": "concurrently \"npm run dev\" \"npm run wechat:start\""
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "telegram": "^2.26.22",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.cryptosidescreen.app",
    "productName": "Crypto Side Screen",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
